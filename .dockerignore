# .dockerignore - Excludes files from Docker build context
# Reduces build time and image size by not copying unnecessary files

# Git
.git
.gitignore
.gitattributes

# Node modules (will be reinstalled in container)
node_modules/
frontend/node_modules/
backend/node_modules/
npm-debug.log
npm-error.log
yarn-error.log
package-lock.json.bak

# Environment files (use --env-file at runtime)
.env.local
.env.*.local
.env.production.local
.env.development.local

# IDE and editor
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db
*.code-workspace

# Build artifacts (frontend only, will be rebuilt)
frontend/dist/
backend/dist/
dist/

# Development
.npm
.eslintcache

# Documentation and metadata
README.md
CHANGELOG.md
LICENSE
*.md
docs/
examples/

# CI/CD
.github/
.gitlab-ci.yml
.circleci/
Jenkinsfile

# Docker
Dockerfile
.dockerignore
docker-compose*.yml
docker-compose.*.yml

# Development/test files
*.test.js
*.spec.js
coverage/
.nyc_output/
test/
tests/

# Database
*.sqlite
*.db
.mongo/
data/

# Temporary files
tmp/
temp/
*.tmp
*.log

# Large media files
*.mp4
*.mp3
*.wav
*.iso

# System files
.DS_Store
.AppleDouble
.LSOverride
Thumbs.db
