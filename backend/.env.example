# ============================================
# DEVOPS HUB BACKEND - ENVIRONMENT VARIABLES
# ============================================
# Copy this file to .env and fill in your values

# ============================================
# SERVER CONFIGURATION
# ============================================
PORT=5000
NODE_ENV=production

# ============================================
# DATABASE (MongoDB Atlas)
# ============================================
# Format: mongodb+srv://username:password@cluster.mongodb.net/database-name?retryWrites=true&w=majority
MONGODB_URI=mongodb://localhost:27017/devops-dashboard

# ============================================
# FRONTEND ORIGINS (CORS)
# ============================================
# Comma-separated list of allowed origins
CLIENT_ORIGIN=http://localhost:3000,http://localhost:5173,https://yourdomain.com

# ============================================
# AUTHENTICATION
# ============================================
JWT_SECRET=your-super-secret-jwt-key-min-32-chars-long

# Firebase Admin SDK
# Set either FIREBASE_ADMIN_KEY or place serviceAccountKey.json in backend/
FIREBASE_ADMIN_KEY=
FIREBASE_PROJECT_ID=your-firebase-project-id

# ============================================
# JENKINS INTEGRATION
# ============================================
JENKINS_URL=http://jenkins-server:8080
JENKINS_USER=admin
JENKINS_USERNAME=admin
JENKINS_TOKEN=your-jenkins-api-token
JENKINS_JOB_NAME=devops-hub-deploy
JENKINS_AUTO_CREATE_JOB=true

# ============================================
# DOCKER CONFIGURATION
# ============================================
DOCKER_HOST=unix:///var/run/docker.sock
DOCKER_VERSION=1.24
REGISTRY_ENCRYPTION_KEY=change-this-32-plus-character-secret

# ============================================
# GITHUB WEBHOOK
# ============================================
GITHUB_WEBHOOK_SECRET=your-github-webhook-secret
GITHUB_TOKEN=your-github-personal-access-token
GITHUB_WEBHOOK_URL=http://localhost:5000/api/webhooks/github
ENABLE_AUTO_DEPLOYMENT=true
WEBHOOK_DEPLOYMENT_MODE=jenkins
WEBHOOK_BUILD_FILE_PATH=auto
WEBHOOK_CONTAINER_NAME=devops-hub
WEBHOOK_CONTAINER_PORTS=3000:3000
WEBHOOK_CONTAINER_ENV=NODE_ENV=production
WEBHOOK_CONTAINER_VOLUMES=
WEBHOOK_ENVIRONMENT=production
WEBHOOK_ENABLE_POST_JENKINS_DEPLOY=false

# Defaults used by POST /deploy, /restart, and /rollback when no body is supplied
CONTAINER_NAME=devops-hub
CONTAINER_IMAGE=devops-hub:latest
CONTAINER_PORTS=3000:3000
CONTAINER_ENV=NODE_ENV=production
CONTAINER_VOLUMES=
ROLLBACK_VERSION=

# ============================================
# AWS CONFIGURATION (for EC2 deployment)
# ============================================
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_EC2_INSTANCE_ID=i-1234567890abcdef0
AWS_EC2_HOST=ec2-public-ip-or-dns
AWS_EC2_USER=ubuntu
AWS_EC2_PORT=22
AWS_EC2_KEY_NAME=your-aws-key-pair-name
AWS_EC2_KEY_PATH=/absolute/path/to/key.pem
# Or provide PEM content instead of AWS_EC2_KEY_PATH:
# AWS_EC2_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----"

# ============================================
# AI ANALYSIS (OpenAI)
# ============================================
# Leave empty to use fallback pattern-based analysis
OPENAI_API_KEY=sk-your-openai-api-key

# ============================================
# ALERT THRESHOLDS
# ============================================
ALERT_CPU_HIGH=85
ALERT_MEMORY_HIGH=85
ALERT_DISK_HIGH=90
ALERT_LATENCY_HIGH=500

# ============================================
# FEATURE FLAGS
# ============================================
ENABLE_AI_ANALYSIS=true
ENABLE_WEBHOOKS=true
ENABLE_METRICS_COLLECTION=true
